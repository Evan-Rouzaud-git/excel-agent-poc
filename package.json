{
  "name": "office-addin-taskpane-js",
  "version": "0.0.1",
  "repository": {
    "type": "git",
      "url": "https://github.com/your-username/portfolio-excel-agent.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "test": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js all",
    "test:format": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js format",
    "test:chart": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js chart",
    "test:formula": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js formula",
    "test:multi": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js multi",
    "test:join": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js join",
    "test:table_view": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js view",
    "test:validate": "cross-env OLLAMA_DISABLED=1 node tests/scripts/run-suite.js validate",
    "test:demoEval": "node tests/scripts/run-suite.js demoeval",
    "test:demoEval:view": "node tests/scripts/run-suite.js demoeval ollama table_view",
    "test:demoEval:view:mock": "node tests/scripts/run-suite.js demoeval mock table_view",
    "test:demoEval:mock": "cross-env DEMO_EVAL_MODE=mock node tests/scripts/run-suite.js demoeval mock",
    "test:demoEval:ollama": "cross-env DEMO_EVAL_MODE=ollama node tests/scripts/run-suite.js demoeval ollama",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "core-js": "^3.36.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@types/jest": "^29.5.14",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "acorn": "^8.11.3",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^10.1.0",
    "eslint-plugin-office-addins": "^4.0.3",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
